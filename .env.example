# WIKEv2Connect Development Environment

# Logging level for development
RUST_LOG=debug

# Build in release mode for testing
CARGO_PROFILE_RELEASE_LTO=true
CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1

# For actual VPN testing (OPTIONAL - use test credentials only)
# WIKEv2Connect_TEST_SERVER=xxx.xxx.xxx.xxx
# WIKEv2Connect_TEST_USER=TestUser
# WIKEv2Connect_TEST_PASSWORD=TestPassword
